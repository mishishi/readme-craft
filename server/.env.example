# MiniMax API 配置
MINIMAX_API_KEY=your_minimax_api_key_here
# MiniMax 模型 (默认 MiniMax-Text-01)
MINIMAX_MODEL=MiniMax-Text-01
# 如果需要 GroupId (某些 MiniMax 账号需要)
# MINIMAX_GROUP_ID=your_group_id_here

# GitHub API Token (可选，不配则 60次/小时，配了飙到 5000次/小时)
# https://github.com/settings/tokens 创建，不需要任何权限
# GITHUB_TOKEN=your_github_token_here

# 服务端口
PORT=3001
