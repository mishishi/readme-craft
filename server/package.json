{
  "name": "readme-craft-server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "lsof -ti:3001 | xargs kill -9 2>/dev/null; unset SSL_CERT_FILE; HTTPS_PROXY=http://127.0.0.1:7890 NODE_TLS_REJECT_UNAUTHORIZED=0 tsx watch src/index.ts",
    "build": "tsc",
    "start": "unset SSL_CERT_FILE; node dist/index.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.1.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.3",
    "sql.js": "^1.14.1",
    "undici": "^6.20.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/sql.js": "^1.4.11",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
